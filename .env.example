#請複製並重新命名成.env

# Bot Token（必須）- 請從 Discord Developer Portal 取得
DISCORD_TOKEN = 'insert_your_bot_token_here'

# 應用程式 ID（必須）- 用於註冊 Slash 指令
DISCORD_APPLICATION_ID = 'insert_your_application_id_here'

# 伺服器 ID（可選）- 指定則僅在該伺服器註冊指令，留空則全域註冊
DISCORD_GUILD_ID = 'global'

# 頻道 ID（可選）- 指定則僅監聽該頻道，留空則全域監聽
DISCORD_CHANNEL_ID = 'global'

# 擁有者使用者 ID（建議設定）- 用於 DM 權限控制
DISCORD_USER_ID = 'insert_your_user_id_here'