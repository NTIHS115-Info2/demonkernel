{
  "scripts": {
    "test": "vitest --globals",
    "lint": "eslint .",
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && yarn copy:assets",
    "copy:assets": "cpy \"src/**/plugin.manifest.json\" \"src/**/assets/**\" \"dist\" --parents",
    "start": "yarn build && node dist/index.js",
    "updatelog:new": "node tools/updatelog/cli.js new",
    "updatelog:ensure": "node tools/updatelog/cli.js ensure --staged",
    "updatelog:validate:staged": "node tools/updatelog/cli.js validate --staged",
    "updatelog:validate:push": "node tools/updatelog/cli.js validate --push",
    "prepare": "husky install"
  },
  "name": "demonkernel",
  "version": "0.1",
  "main": "index.js",
  "repository": "https://github.com/sandwichcookice/demonkernel.git",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "tar": "7.5.8"
  }
}
